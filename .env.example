# ─── Firebase ───────────────────────────────────────────────
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID_WEB=1:123456789:web:abcdef
FIREBASE_APP_ID_ANDROID=1:123456789:android:abcdef
FIREBASE_APP_ID_IOS=1:123456789:ios:abcdef
FIREBASE_IOS_CLIENT_ID=123456789-abc.apps.googleusercontent.com
FIREBASE_IOS_BUNDLE_ID=com.yourcompany.chatloc

# ─── Google Maps ────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── App ────────────────────────────────────────────────────
APP_NAME=ChatLoc
APP_ENV=development
